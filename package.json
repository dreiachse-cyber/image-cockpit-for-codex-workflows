    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
